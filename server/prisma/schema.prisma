generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model Harvest {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  quantity  Float?
  loggedBy  Int
}

model Employee {
  id        Int      @id @default(autoincrement())
  tgId      BigInt?
  name      String
}